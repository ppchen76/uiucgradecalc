    <h2>Grade Calculator</h2>
    
    <div class="grid">
        <div>
            <label>Syllabus Quiz (2%)</label>
            <input type="number" id="sylQuiz" placeholder="%">
        </div>
        <div>
            <label>Attendance (3%)</label>
            <input type="number" id="attend" placeholder="%">
        </div>
        <div>
            <label>Online Lab Att. (10%)</label>
            <input type="number" id="labAtt" placeholder="%">
        </div>
        <div>
            <label>Nonlab HW (8%)</label>
            <input type="number" id="nlHW" placeholder="%">
        </div>
        <div>
            <label>Lab HW (5%)</label>
            <input type="number" id="labHW" placeholder="%">
        </div>
        <div>
            <label>Python Quizzes (6%)</label>
            <input type="number" id="pyQuiz" placeholder="Avg %">
        </div>
        
        <div class="full"><hr></div>
        
        <div class="full">
            <label>Midterm Scores (16% each)</label>
            <div class="mid-grid">
                <input type="number" id="m1" placeholder="M1">
                <input type="number" id="m2" placeholder="M2">
                <input type="number" id="m3" placeholder="M3">
            </div>
        </div>

        <div class="full">
            <label>Target Class Grade (%)</label>
            <input type="number" id="target" placeholder="e.g., 90">
        </div>
    </div>

    <button onclick="calculate()">Calculate Required Final Score</button>

    <div id="result"></div>
</div>

<script>
    function calculate() {
        const sQ = parseFloat(document.getElementById('sylQuiz').value) || 0;
        const att = parseFloat(document.getElementById('attend').value) || 0;
        const lA = parseFloat(document.getElementById('labAtt').value) || 0;
        const nHW = parseFloat(document.getElementById('nlHW').value) || 0;
        const lHW = parseFloat(document.getElementById('labHW').value) || 0;
        const pQ = parseFloat(document.getElementById('pyQuiz').value) || 0;
        const m1 = parseFloat(document.getElementById('m1').value) || 0;
        const m2 = parseFloat(document.getElementById('m2').value) || 0;
        const m3 = parseFloat(document.getElementById('m3').value) || 0;
        const target = parseFloat(document.getElementById('target').value);

        if (isNaN(target)) { alert("Please enter a target grade."); return; }

        const wFixed = (sQ * 0.02) + (att * 0.03) + (lA * 0.10) + (nHW * 0.08) + (lHW * 0.05) + (pQ * 0.06);

        const midterms = [m1, m2, m3];
        const lowestMid = Math.min(...midterms);
        const sumOtherMids = midterms.reduce((a, b) => a + b, 0) - lowestMid;
        
        // Final (18%) replaces lowest Midterm (16%)
        // Points needed = Target - FixedPoints - (Remaining Midterms * 0.16)
        // Effective Weight = 0.18 (Final) + 0.16 (Replacement) = 0.34
        
        const pointsNeeded = target - wFixed - (sumOtherMids * 0.16);
        const effectiveWeight = 0.34;
        const needed = pointsNeeded / effectiveWeight;

        const res = document.getElementById('result');
        res.style.display = 'block';
        res.className = needed > 100 ? 'warning' : 'success';
        
        if (needed <= 0) {
            res.innerHTML = `🎉 You've reached your goal! You can get a 0% on the final.`;
        } else {
            res.innerHTML = `To get a ${target}%, you need a <strong>${needed.toFixed(2)}%</strong> on the final.<br>
            <small>(Replaces your ${lowestMid}% midterm)</small>`;
        }
    }
</script>

