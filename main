<body>

<div class="card">
    <h2>Smart Grade Calc</h2>
    <p class="info">This calculator replaces your lowest midterm with your Final Exam score automatically.</p>
    
    <label>Midterm Scores (%)</label>
    <div class="row">
        <input type="number" id="m1" placeholder="M1">
        <input type="number" id="m2" placeholder="M2">
        <input type="number" id="m3" placeholder="M3">
    </div>

    <label>Other Grades Average (HW, Quiz, etc %)</label>
    <input type="number" id="other" placeholder="e.g. 95">

    <label>Target Class Grade (%)</label>
    <input type="number" id="target" placeholder="e.g. 90">

    <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">
    
    <label>Weight of EACH Midterm (%)</label>
    <input type="number" id="wMid" placeholder="e.g. 15">

    <label>Weight of Final Exam (%)</label>
    <input type="number" id="wFinal" placeholder="e.g. 25">

    <button onclick="calculateReplacement()">Calculate Goal</button>

    <div id="result"></div>
</div>

<script>
    function calculateReplacement() {
        // Inputs
        const m1 = parseFloat(document.getElementById('m1').value) || 0;
        const m2 = parseFloat(document.getElementById('m2').value) || 0;
        const m3 = parseFloat(document.getElementById('m3').value) || 0;
        const other = parseFloat(document.getElementById('other').value) || 0;
        const target = parseFloat(document.getElementById('target').value);
        
        // Weights
        const wMid = parseFloat(document.getElementById('wMid').value) / 100;
        const wFinal = parseFloat(document.getElementById('wFinal').value) / 100;
        
        const midterms = [m1, m2, m3];
        const lowestMidterm = Math.min(...midterms);
        const otherMidtermsSum = midterms.reduce((a, b) => a + b, 0) - lowestMidterm;
        
        // Weight of "Other" (everything else)
        const wOther = 1 - (wMid * 3) - wFinal;
        
        // Logic: Target = (Remaining Midterms * wMid) + (Other * wOther) + (Final * wFinal) + (Final replaces lowest Midterm * wMid)
        // Simplified: Target = (Remaining Midterms * wMid) + (Other * wOther) + [Final * (wFinal + wMid)]
        
        const knownPoints = (otherMidtermsSum * wMid) + (other * wOther);
        const requiredWeight = wFinal + wMid;
        const needed = (target - knownPoints) / requiredWeight;

        const resultDiv = document.getElementById('result');
        resultDiv.style.display = 'block';
        resultDiv.style.backgroundColor = needed > 100 ? '#fce8e6' : '#e6f4ea';
        
        if (needed <= 0) {
            resultDiv.innerHTML = "You're golden! You can get a 0% on the final and still hit your goal.";
        } else {
            resultDiv.innerHTML = `Since it replaces your ${lowestMidterm}%, you need a <strong>${needed.toFixed(2)}%</strong> on the final to get a ${target}% total.`;
        }
    }
</script>

